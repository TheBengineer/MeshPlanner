    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-map-gl": "^7.1.9",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-precaching": "^7.4.1",
    "workbox-routing": "^7.4.1",
    "workbox-strategies": "^7.4.1",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@playwright/test": "^1.61.1",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "oxlint": "^1.69.0",
    "rollup-plugin-visualizer": "^6.0.11",
    "typescript": "~6.0.2",
    "vite": "^8.1.0",
